# Copy this file to .env and adjust as needed:  cp .env.example .env
# All model names and thresholds are read at runtime — swap models by editing
# this file only, with zero code changes. Defaults are lightweight and run on
# any machine. Validate everything with:  uv run python -m src.config

# --- Cloud LLM API Keys (multi-provider router: NVIDIA -> Groq -> Gemini) ---
# NVIDIA is PRIMARY (500 free credits, high quality). Groq is fast fallback.
# Cerebras REMOVED — llama3.1-8b and llama3.3-70b both 404 on this account.
CEREBRAS_API_KEY=your_cerebras_key_here
# Get free key at: https://console.groq.com
GROQ_API_KEY=your_groq_key_here
# Get free key at: https://aistudio.google.com (no credit card required)
GEMINI_API_KEY=your_gemini_key_here
# Get free key at: https://build.nvidia.com (500 free credits)
NVIDIA_API_KEY=your_nvidia_key_here

ROUTER_VISION_MODELS=gemini/gemini-2.0-flash,nvidia_nim/meta/llama-3.2-90b-vision-instruct

# --- FalkorDB (graph + vector + full-text store) ---
FALKORDB_HOST=localhost
FALKORDB_PORT=6379
# Optional: graph name (default: document_graph)
# FALKORDB_GRAPH=document_graph

# --- Ollama (vision captioning + embeddings only — LLM calls now use cloud) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=phi3.5:3.8b          # kept as local fallback only
OLLAMA_VISION_MODEL=moondream         # local vision model for image captions
OLLAMA_EMBED_MODEL=nomic-embed-text   # must produce 768-dim vectors

# --- Re-ranking (Cloud NVIDIA NIM API) ---
CROSS_ENCODER_MODEL=nvidia/rerank-qa-mistral-4b

# --- Entity extraction (GLiNER) ---
GLINER_MODEL=urchade/gliner_small-v2.1

# --- Thresholds ---
SPLINK_MERGE_THRESHOLD=0.85           # entity-resolution merge cutoff (0-1)
ADVERSARIAL_SCORE_THRESHOLD=0.3       # threshold for preventing hallucination
GLINER_CONFIDENCE_THRESHOLD=0.7       # GLiNER entity confidence cutoff (0-1)
CHUNK_MAX_TOKENS=512                  # max tokens per chunk

# --- Directories (relative to project root) ---
FIGURES_DIR=data/figures
UPLOADS_DIR=data/uploads
# Optional: outputs dir (default: data/outputs)
# OUTPUTS_DIR=data/outputs
