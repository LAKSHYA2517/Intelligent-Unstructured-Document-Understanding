# Copy this file to .env and adjust as needed:  cp .env.example .env
# All model names and thresholds are read at runtime — swap models by editing
# this file only, with zero code changes. Defaults are lightweight and run on
# any machine. Validate everything with:  uv run python -m src.config

# --- FalkorDB (graph + vector + full-text store) ---
FALKORDB_HOST=localhost
FALKORDB_PORT=6379
# Optional: graph name (default: document_graph)
# FALKORDB_GRAPH=document_graph

# --- Ollama (all LLM / vision / embedding inference) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=phi3.5:3.8b          # e.g. llama3.1:8b on a stronger machine
OLLAMA_VISION_MODEL=moondream         # e.g. llava:7b
OLLAMA_EMBED_MODEL=nomic-embed-text   # must produce 768-dim vectors

# --- Re-ranking (sentence-transformers cross-encoder) ---
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- Entity extraction (GLiNER) ---
GLINER_MODEL=urchade/gliner_small-v2.1

# --- Thresholds ---
SPLINK_MERGE_THRESHOLD=0.85           # entity-resolution merge cutoff (0-1)
ADVERSARIAL_SCORE_THRESHOLD=0.3       # min relevance to answer (0-1)
GLINER_CONFIDENCE_THRESHOLD=0.7       # GLiNER entity confidence cutoff (0-1)
CHUNK_MAX_TOKENS=512                  # max tokens per chunk

# --- Directories (relative to project root) ---
FIGURES_DIR=data/figures
UPLOADS_DIR=data/uploads
# Optional: outputs dir (default: data/outputs)
# OUTPUTS_DIR=data/outputs
